// overseer.js
// Overseer V-Bot: Vault-Tec supervisory intelligence for Vault 77 / Wasteland GPS.
// Handles terminal chat, basic commands, and hooks into gameState/world as they come online.

(function () {
  const chatEl = document.getElementById("chat");
  const inputEl = document.getElementById("input");
  const sendBtn = document.getElementById("send");
  const rmControls = document.getElementById("rmControls");
  const mgcRoot = document.getElementById("mobileGameControls");
  const mgcHeader = document.getElementById("mgcHeader");
  const mgcGeneric = document.getElementById("mgcGeneric");
  const mgcDpad = document.getElementById("mgcDpad");
  const mgcNumpad = document.getElementById("mgcNumpad");

  const gs = window.gameState || null;

  // --- UTILITIES ------------------------------------------------------------

  function nowStamp() {
    return new Date().toISOString().split("T")[1].split(".")[0];
  }

  function scrollChatToBottom() {
    if (!chatEl) return;
    chatEl.scrollTop = chatEl.scrollHeight;
  }

  function appendLine(text, type = "system") {
    if (!chatEl) return;

    const line = document.createElement("div");
    line.className = `line line-${type}`;
    line.textContent = text;
    chatEl.appendChild(line);
    scrollChatToBottom();
  }

  function appendBlock(lines, type = "system") {
    lines.forEach((l) => appendLine(l, type));
  }

  function normalizeInput(str) {
    return (str || "").trim();
  }

  function explodeCommand(input) {
    const raw = normalizeInput(input);
    if (!raw) return { cmd: "", args: [] };
    const parts = raw.split(/\s+/);
    const cmd = parts[0].toLowerCase();
    const args = parts.slice(1);
    return { cmd, args, raw };
  }

  function safeAccess(obj, path, fallback = null) {
    try {
      return path.split(".").reduce((acc, key) => (acc ? acc[key] : undefined), obj) ?? fallback;
    } catch {
      return fallback;
    }
  }

  // --- OVERSEER VOICE -------------------------------------------------------

  const overseerName = "OVERSEER V-BOT // V-77";

  function overseerSay(text) {
    appendLine(`[${overseerName} ${nowStamp()}] ${text}`, "overseer");
  }

  function overseerSayBlock(lines) {
    lines.forEach((l) => overseerSay(l));
  }

  function overseerError(text) {
    appendLine(`[${overseerName} ERROR] ${text}`, "error");
  }

  function userSay(text) {
    appendLine(`> ${text}`, "user");
  }

  // --- INITIAL BOOT SEQUENCE ------------------------------------------------

  function bootSequence() {
    appendBlock(
      [
        ">> INITIALIZING VAULT-TEC RESTRICTED TERMINAL...",
        ">> ROUTING THROUGH ATOMIC FIZZ CAPS WASTELAND GPS BACKBONE...",
        ">> SIGNAL STRENGTH: WEAK // INTERFERENCE: HIGH",
        "",
      ],
      "system"
    );

    overseerSayBlock([
      "Vault 77 supervisory routines online.",
      "Overseer V-Bot reporting. Limited uplink to surface telemetry established.",
      "Type `help` for a list of supported commands.",
    ]);
  }

  // --- COMMAND HANDLERS -----------------------------------------------------

  const handlers = {
    help(_args) {
      overseerSayBlock([
        "Recognized commands:",
        "  help        - Display this help.",
        "  status      - Report player and vault status.",
        "  map         - Report current region and nearby points of interest.",
        "  radio       - Report or control radio subsystem.",
        "  quests      - List active quests (if quest engine is online).",
        "  diagnostics - Show high-level system state for debugging.",
        "  rm          - Toggle Red Menace controls (if available).",
        "  clear       - Clear terminal log.",
        "  ping        - Verify Overseer responsiveness.",
      ]);
    },

    ping() {
      overseerSay("Ping received. Vault-Tec supervisory core still disturbingly conscious.");
    },

    clear() {
      if (!chatEl) return;
      chatEl.innerHTML = "";
      bootSequence();
    },

    status() {
      if (!gs) {
        overseerError("No gameState detected. Pip-Boy link not established.");
        return;
      }

      const lvl = safeAccess(gs, "player.level", "?");
      const hp = safeAccess(gs, "player.hp", "?");
      const maxHp = safeAccess(gs, "player.maxHp", "?");
      const caps = safeAccess(gs, "player.caps", "?");
      const xp = safeAccess(gs, "player.xp", "?");
      const weapon = safeAccess(gs, "player.equipped.weapon.name", "UNARMED");
      const armor = safeAccess(gs, "player.equipped.armor.name", "NONE");

      overseerSayBlock([
        "Pip-Boy telemetry received:",
        `  LEVEL: ${lvl}`,
        `  HEALTH: ${hp} / ${maxHp}`,
        `  CAPS: ${caps}`,
        `  XP: ${xp}`,
        `  EQUIPPED WEAPON: ${weapon}`,
        `  EQUIPPED ARMOR: ${armor}`,
      ]);
    },

    map() {
      const world = window.world;
      if (!world || !gs) {
        overseerError("World module or player telemetry missing. Cannot resolve regional data.");
        return;
      }

      const region = world.getCurrentRegion ? world.getCurrentRegion() : null;
      const pos = gs.player.position || { lat: "?", lng: "?" };
      const nearby = world.getNearbyPOIs ? world.getNearbyPOIs(750) : [];

      overseerSay(`Current coordinates: LAT ${pos.lat} / LNG ${pos.lng}`);

      if (region) {
        overseerSay(`Detected region: ${region.name} [${region.id}] // Style: ${region.mapStyle}`);
      } else {
        overseerSay("No registered region at current coordinates. You may be outside calibrated Mojave corridors.");
      }

      if (!nearby.length) {
        overseerSay("No nearby points of interest within 750 meters.");
      } else {
        overseerSay("Nearby points of interest:");
        nearby.forEach((entry) => {
          const p = entry.poi;
          const dist = Math.round(entry.distanceMeters);
          overseerSay(`  - ${p.name} [${p.id}] at ~${dist}m`);
        });
      }
    },

    radio(args) {
      const radio = window.radio;
      if (!radio) {
        overseerError("Radio subsystem not linked. Pip-Boy audio bus not exposed to Overseer.");
        return;
      }

      if (!args.length) {
        overseerSay(
          "Radio subsystem detected. Use `radio next` to cycle station from Pip-Boy front-end, or `radio info` for details."
        );
        return;
      }

      const sub = args[0].toLowerCase();

      if (sub === "info") {
        overseerSay(
          "Radio control is primarily handled via Pip-Boy UI. This terminal can only observe or request station changes."
        );
      } else {
        overseerSay(`Radio subcommand '${sub}' is not yet wired. Front-end button remains primary control.`);
      }
    },

    quests() {
      const qs = window.quests;
      if (!qs || !qs.QUESTS_DB || !gs) {
        overseerError("Quest engine not detected or not initialized.");
        return;
      }

      const states = gs.quests || {};
      const all = qs.QUESTS_DB;

      const entries = Object.keys(all).map((id) => {
        const meta = all[id];
        const st = states[id] || { state: "not_started", currentStepIndex: 0 };
        return { id, meta, st };
      });

      if (!entries.length) {
        overseerSay("No registered quest definitions. Vault-Tec narrative layer appears absent.");
        return;
      }

      overseerSay("Quest telemetry:");
      entries.forEach(({ id, meta, st }) => {
        const step =
          st.state === "active" ? meta.steps[st.currentStepIndex]?.description || "Unknown objective" : "";
        overseerSay(
          `  - ${meta.name} [${id}] :: STATE=${st.state.toUpperCase()}${
            step ? ` :: CURRENT OBJECTIVE: ${step}` : ""
          }`
        );
      });
    },

    diagnostics() {
      overseerSay("Initiating Vault 77 diagnostics scan...");

      const checks = [
        ["gameState", !!window.gameState],
        ["world", !!window.world],
        ["quests", !!window.quests],
        ["radio", !!window.radio],
        ["encounters", !!window.encounters],
        ["battle", !!window.battle],
        ["inventory", !!window.inventory],
      ];

      checks.forEach(([name, ok]) => {
        overseerSay(`  ${name.toUpperCase()}: ${ok ? "ONLINE" : "OFFLINE"}`);
      });

      overseerSay(
        "Note: OFFLINE subsystems may still be under construction by Vault engineers. Consult your nearest Atomic Fizz representative."
      );
    },

    rm() {
      if (!rmControls) {
        overseerError("Red Menace control block not present in DOM.");
        return;
      }

      const visible = rmControls.style.display === "block";
      rmControls.style.display = visible ? "none" : "block";
      overseerSay(visible ? "Red Menace controls hidden." : "Red Menace controls exposed. Try not to die.");
    },
  };

  // --- MOBILE GAME CONTROLS BRIDGE (D-PAD ETC.) -----------------------------

  function initMobileControls() {
    if (!mgcRoot) return;

    // Currently mostly cosmetic; you can wire these to mini-games or map movement.
    const dpadButtons = mgcRoot.querySelectorAll(".dpad-btn");
    dpadButtons.forEach((btn) => {
      btn.addEventListener("click", () => {
        const dir = btn.getAttribute("data-dir");
        overseerSay(`Movement input registered: ${dir.toUpperCase()}. No surface avatar motion mapped yet.`);
      });
    });

    mgcHeader.textContent = "MOBILE GAME CONTROLS // VAULT-TEC FIELD HARNESS";
  }

  // --- INPUT HANDLING -------------------------------------------------------

  function handleSubmit() {
    const raw = inputEl ? inputEl.value : "";
    const trimmed = normalizeInput(raw);
    if (!trimmed) return;

    userSay(trimmed);
    if (inputEl) inputEl.value = "";

    const { cmd, args } = explodeCommand(trimmed);
    if (!cmd) return;

    const handler = handlers[cmd];
    if (handler) {
      try {
        handler(args);
      } catch (err) {
        console.error("Overseer handler error:", err);
        overseerError("Internal handler fault. Vault 77 software stack remains characteristically unstable.");
      }
    } else {
      overseerSay(
        `Unrecognized directive '${cmd}'. Type 'help' for an approved list of Vault-Tec supported interactions.`
      );
    }
  }

  function wireInput() {
    if (!inputEl || !sendBtn) return;

    sendBtn.addEventListener("click", handleSubmit);

    inputEl.addEventListener("keydown", (ev) => {
      if (ev.key === "Enter") {
        ev.preventDefault();
        handleSubmit();
      }
    });
  }

  // --- STYLE HOOKS / CLASSNAMES --------------------------------------------

  function injectBasicStyles() {
    // Optional class-based styling hook if you want in CSS:
    // .line-system, .line-overseer, .line-user, .line-error
    // Already used in appendLine type argument.
  }

  // --- INIT -----------------------------------------------------------------

