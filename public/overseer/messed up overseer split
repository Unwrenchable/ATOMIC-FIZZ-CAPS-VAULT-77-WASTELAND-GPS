(function () {
  const stations = [
    { id: "wasteland_classics", src: "/radio/wasteland_classics.mp3" },
    { id: "atomic_swing", src: "/radio/atomic_swing.mp3" },
    { id: "vault77_broadcast", src: "/radio/vault77_broadcast.mp3" }
  ];

  let audio = null;
  let currentIndex = -1; // -1 = OFF

  function initRadio() {
    audio = document.getElementById("radioPlayer");
    const btn = document.getElementById("radioToggle");

    if (!audio || !btn) return;

    btn.addEventListener("click", toggleRadio);
  }

  function toggleRadio() {
    // Move to next station
    currentIndex++;

    // If past last station → turn radio OFF
    if (currentIndex >= stations.length) {
      currentIndex = -1;
      audio.pause();
      audio.src = "";
      console.log("Radio OFF");
      return;
    }

    // Play selected station
    const station = stations[currentIndex];
    audio.src = station.src;
    audio.loop = true;
    audio.play().catch(console.error);

    console.log("Radio playing:", station.id);
  }

  window.addEventListener("load", initRadio);
})();

